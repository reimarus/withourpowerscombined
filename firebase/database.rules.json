{
  "rules": {
    "games": {
      "$game_id": {
        ".read": true,
        ".write": true,
        ".validate": "newData.hasChildren(['host_name','map_name','player_count','max_players','lobby_port','host_ip','last_seen'])"
      }
    },
    "reports": {
      "$report_id": {
        ".read": false,
        ".write": true,
        ".validate": "newData.hasChildren(['timestamp','host_name','log','version'])"
      }
    },
    "logs": {
      "$log_id": {
        ".read": false,
        ".write": true,
        ".validate": "newData.hasChildren(['event','timestamp'])"
      }
    }
  }
}
